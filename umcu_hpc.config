profiles {
    slurm {
        process {
            executor = 'slurm'
            queue = 'cpu'
            clusterOptions = " --gres=tmpspace:10G"

            errorStrategy = 'retry'
            maxRetries = 1
        }

        singularity {
            enabled = true
            runOptions = '-B /hpc:/hpc -B $TMPDIR:$TMPDIR'
            autoMounts = true
            cacheDir = '/hpc/hers_en/edejong2/software/singularity_cache/'
            pullTimeout = '1h'
        }

        executor {
            queueSize = 1000
            pollInterval = '1min'
            queueStatInterval = '5min'
            submitRatelimit = '10sec'
        }
    }
}
